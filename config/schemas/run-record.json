{
  "$id": "run-record",
  "type": "object",
  "required": ["ts", "persona", "repo", "trigger", "outcome"],
  "properties": {
    "ts": {"type": "string", "description": "ISO-8601 timestamp of the run"},
    "persona": {"type": "string"},
    "repo": {"type": "string"},
    "trigger": {"type": "string"},
    "outcome": {"type": "string"},
    "cost_tokens": {
      "type": "number",
      "description": "Total tokens consumed; harness-sourced from API response metadata, not self-reported by the model"
    }
  }
}
